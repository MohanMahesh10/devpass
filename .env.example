# ---- Azure Storage (Table Storage) ----
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# ---- Azure Communication Services (Email) ----
ACS_CONNECTION_STRING=endpoint=https://<your-acs>.communication.azure.com/;accesskey=...
ACS_SENDER_EMAIL=DoNotReply@devpass.azurecomm.net

# ---- Admin auth ----
ADMIN_PASSWORD=change-me-please
SESSION_SECRET=some-long-random-string

# ---- Event details ----
EVENT_ID=devpass-2025
EVENT_NAME=DevPass 2025
EVENT_DATE=2025-08-15
EVENT_VENUE=Your Venue Here

# ---- Server ----
PORT=3001
# Comma-separated list of allowed origins for CORS (e.g. your Static Web App URL)
CLIENT_ORIGIN=http://localhost:3000
